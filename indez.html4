<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Matheus Viana | Strategic Engineering</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #050505; color: #e2e2e2; }
        .mono { font-family: 'JetBrains Mono', monospace; }
        .gradient-border {
            border: 1px solid;
            border-image: linear-gradient(to right, #1a1a1a, #333, #1a1a1a) 1;
        }
        .glow { box-shadow: 0 0 20px rgba(0, 255, 128, 0.1); }
        .aurora-accent { color: #00ff80; }
    </style>
</head>
<body class="overflow-x-hidden">

    <!-- Navbar -->
    <nav class="flex justify-between items-center px-8 py-6 border-b border-white/5 bg-black/50 backdrop-blur-md fixed w-full z-50">
        <div class="text-xl font-extrabold tracking-tighter">MV <span class="aurora-accent">SYSTEMS</span></div>
        <div class="hidden md:flex gap-8 text-xs uppercase tracking-widest mono">
            <a href="#" class="hover:text-emerald-400 transition">Projetos</a>
            <a href="#" class="hover:text-emerald-400 transition">Hardware</a>
            <a href="#" class="hover:text-emerald-400 transition">Software</a>
            <a href="#" class="hover:text-emerald-400 transition">Aurora V4.1</a>
        </div>
        <div class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></div>
    </nav>

    <!-- Hero Section -->
    <section class="min-h-screen flex flex-col justify-center px-8 pt-20">
        <div class="max-w-6xl mx-auto w-full">
            <h1 class="text-6xl md:text-8xl font-extrabold tracking-tight mb-4">
                MATHEUS <br> <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-blue-500">DOS SANTOS VIANA</span>
            </h1>
            <p class="max-w-2xl text-gray-400 text-lg md:text-xl mb-8 leading-relaxed">
                Engenharia de alta precisão. Desenvolvimento Full-Stack e Sistemas Embarcados. 
                Sincronizado com o Protocolo Aurora para execução de projetos críticos.
            </p>
            <div class="flex gap-4">
                <button class="bg-emerald-600 hover:bg-emerald-500 text-black font-bold py-3 px-8 rounded-sm transition-all uppercase text-xs tracking-widest">
                    Iniciar Novo Projeto
                </button>
                <button class="border border-white/20 hover:border-emerald-500 py-3 px-8 rounded-sm transition-all uppercase text-xs tracking-widest mono">
                    Documentação Técnica
                </button>
            </div>
        </div>
    </section>

    <!-- Tech Stack Grid -->
    <section class="py-20 px-8 bg-[#080808]">
        <div class="max-w-6xl mx-auto">
            <h2 class="mono text-xs text-emerald-500 mb-10 uppercase tracking-[0.3em]">Core Expertise</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Card 1 -->
                <div class="p-8 border border-white/5 bg-white/5 hover:bg-white/10 transition-all group">
                    <div class="h-1 w-12 bg-emerald-500 mb-6 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-bold mb-4 uppercase">Engenharia Mecânica</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">Desenvolvimento de hardware robusto, modelagem 3D e otimização de sistemas físicos.</p>
                </div>
                <!-- Card 2 -->
                <div class="p-8 border border-white/5 bg-white/5 hover:bg-white/10 transition-all group">
                    <div class="h-1 w-12 bg-blue-500 mb-6 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-bold mb-4 uppercase">Full Stack Dev</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">Arquitetura de software escalável, do backend crítico às interfaces neurais responsivas.</p>
                </div>
                <!-- Card 3 -->
                <div class="p-8 border border-white/5 bg-white/5 hover:bg-white/10 transition-all group">
                    <div class="h-1 w-12 bg-purple-500 mb-6 group-hover:w-full transition-all duration-500"></div>
                    <h3 class="text-xl font-bold mb-4 uppercase">Intelligence Integration</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">Implementação do Protocolo Aurora para automação e análise preditiva de dados.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Status Footer -->
    <footer class="py-10 px-8 border-t border-white/5 mono text-[10px] text-gray-600 flex justify-between items-center">
        <div>STATUS: SISTEMA OPERACIONAL // AURORA V4.1 ATIVA</div>
        <div>© 2024 MATHEUS VIANA - TODOS OS PROTOCOLOS RESERVADOS</div>
        <div class="flex gap-4">
            <span class="aurora-accent">LATENCY: 14ms</span>
            <span>ENCRYPTED CONNECTION</span>
        </div>
    </footer>

</body>
</html>